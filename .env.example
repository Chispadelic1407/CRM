# Database Configuration
DATABASE_URL=mysql://username:password@hostname:3306/database_name
RDS_HOSTNAME=your-rds-endpoint.region.rds.amazonaws.com
RDS_PORT=3306
RDS_DB_NAME=crm_production
RDS_USERNAME=crmadmin
RDS_PASSWORD=your-secure-password

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
AGENT_PHONE_NUMBER=+1234567890
VOICE_WEBHOOK_URL=https://your-app-url.elasticbeanstalk.com

# Security
JWT_SECRET=your-super-secure-jwt-secret-key
ENCRYPTION_KEY=your-32-character-encryption-key
SESSION_SECRET=your-session-secret-key

# Application Configuration
NODE_ENV=production
PORT=8080
ALLOWED_ORIGINS=https://your-domain.com,https://your-app-url.elasticbeanstalk.com

# Google AI (Gemini) Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/crm-app.log

# Cache Configuration
REDIS_URL=redis://your-redis-endpoint:6379
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/tmp/uploads

# Email Configuration (if needed)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
