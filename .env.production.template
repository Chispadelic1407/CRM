# Production Environment Configuration Template
# Copy this file to .env and fill in your actual values

NODE_ENV=production
PORT=3000

# Twilio Configuration
# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_NUMBER
AGENT_PHONE_NUMBER=YOUR_AGENT_PHONE_NUMBER

# Gemini AI Configuration
# Get this from Google AI Studio: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Production Domain Configuration
ALLOWED_ORIGINS=https://crm.sebastianvernis.com,http://crm.sebastianvernis.com
VOICE_WEBHOOK_URL=https://crm.sebastianvernis.com

# Database Configuration
DB_PATH=./data/crm_production.db

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/production.log

# Cache Configuration
CACHE_TTL=3600
REDIS_URL=

# Security Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
