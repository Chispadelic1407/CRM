container_commands:
  01_install_dependencies:
    command: "cd /var/app/staging && npm install"
    leader_only: true
  02_run_database_init:
    command: "cd /var/app/staging/backend && node init-database.js"
    leader_only: true
    ignoreErrors: true
  03_set_permissions:
    command: "chmod -R 755 /var/app/current"
    ignoreErrors: true

option_settings:
  aws:elasticbeanstalk:application:environment:
    SEQUELIZE_LOGGING: false
    DB_POOL_MAX: 10
    DB_POOL_MIN: 0
    DB_POOL_ACQUIRE: 30000
    DB_POOL_IDLE: 10000
