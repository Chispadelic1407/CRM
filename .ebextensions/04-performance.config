option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_OPTIONS: "--max-old-space-size=1024"
    UV_THREADPOOL_SIZE: 128
  aws:elasticbeanstalk:container:nodejs:
    GzipCompression: true
    ProxyServer: nginx
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: frontend
    /css: frontend/css
    /js: frontend/js
  aws:elbv2:loadbalancer:
    AccessLogsS3Enabled: true
    IdleTimeout: 60
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced
    EnhancedHealthAuthEnabled: true

files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/01-app-logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/nodejs/nodejs.log*
      /var/app/current/logs/*.log
      /var/log/eb-engine.log
      /var/log/eb-hooks.log

  "/etc/nginx/conf.d/gzip.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      gzip on;
      gzip_comp_level 4;
      gzip_types
        text/plain
        text/css
        application/json
        application/javascript
        text/xml
        application/xml
        application/xml+rss
        text/javascript;

  "/etc/nginx/conf.d/proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      client_max_body_size 10M;
      proxy_connect_timeout 60s;
      proxy_send_timeout 60s;
      proxy_read_timeout 60s;

container_commands:
  01_setup_logs_directory:
    command: "mkdir -p /var/app/current/logs && chmod 755 /var/app/current/logs"
    ignoreErrors: true
  02_setup_tmp_directory:
    command: "mkdir -p /tmp/uploads && chmod 755 /tmp/uploads"
    ignoreErrors: true
